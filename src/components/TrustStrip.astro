---
import type enJson from '../i18n/en.json';
type I18n = typeof enJson;

export interface Props {
  t: I18n;
}

const { t } = Astro.props;
---

<section id="trust" class="bg-paper-deep border-y border-line py-6 overflow-hidden" aria-label="Trust indicators">
  <div class="container mx-auto px-6 md:px-10 lg:px-16">
    <ul class="flex flex-wrap items-center justify-center gap-3 md:gap-4" role="list" aria-label="Quality assurances">
      {t.trust.pills.map((pill) => (
        <li class="trust-pill pill relative overflow-hidden">
          <!-- Shine sweep: polishes across each pill after it appears -->
          <span
            class="pill-shine"
            aria-hidden="true"
            style="position:absolute;inset:0;background:linear-gradient(110deg,transparent 20%,rgba(255,255,255,0.55) 50%,transparent 80%);transform:translateX(-100%);pointer-events:none;"
          ></span>
          {pill}
        </li>
      ))}
    </ul>
  </div>
</section>
