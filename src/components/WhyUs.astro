---
import type enJson from '../i18n/en.json';
type I18n = typeof enJson;

export interface Props {
  t: I18n;
}

const { t } = Astro.props;
---

<section id="why-us" class="py-24 md:py-32 bg-paper-deep" aria-labelledby="why-us-heading">
  <div class="container mx-auto px-6 md:px-10 lg:px-16">

    <div class="mb-14 md:mb-16" id="why-header">
      <p class="section-num mb-2">{t.why_us.section_num}</p>
      <h2 id="why-us-heading" class="eyebrow wipe-reveal-parent relative overflow-hidden inline-block">
        <span class="wipe-text">{t.why_us.eyebrow}</span>
        <span class="wipe-curtain" aria-hidden="true" style="position:absolute;inset:0;background:var(--terra);transform-origin:left center;"></span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-x-12 gap-y-0 md:gap-x-20">
      {t.why_us.items.map((item) => (
        <article class="why-card py-10 border-t border-line">
          <p class="why-num font-serif italic text-terra font-medium leading-none mb-5"
             style="font-size:clamp(2.5rem,5vw,4rem);" aria-hidden="true">
            {item.num}
          </p>
          <h3 class="font-serif font-medium text-xl md:text-2xl text-ink mb-3">{item.title}</h3>
          <p class="font-sans text-muted text-base leading-relaxed">{item.body}</p>
          <span class="why-line block mt-6" aria-hidden="true" style="height:1px;width:0;background:var(--terra);opacity:0.35;"></span>
        </article>
      ))}
    </div>

  </div>
</section>
