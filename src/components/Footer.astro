---
import type enJson from '../i18n/en.json';
type I18n = typeof enJson;

export interface Props {
  t: I18n;
  lang: 'en' | 'th';
}

const { t, lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-paper-deep border-t border-line" aria-label="Site footer">

  <!-- Main footer content -->
  <div class="container mx-auto px-6 md:px-10 lg:px-16 py-16 md:py-20">
    <div class="grid md:grid-cols-3 gap-12 md:gap-16">

      <!-- Col 1: Wordmark + taglines -->
      <div>
        <a href={`/${lang}/`} class="wordmark block mb-5" aria-label="Dee Cleaning Co.">
          <span class="font-serif font-medium text-base text-ink">
            <em class="italic text-terra" style="font-style: italic;">Dee</em><br />
            Cleaning Co.
          </span>
        </a>
        <p class="font-serif italic text-muted text-sm mb-1">
          {t.footer.tagline}
        </p>
        <p class="font-thai text-muted text-sm" lang="th">
          {t.footer.tagline_thai}
        </p>
      </div>

      <!-- Col 2: Contact -->
      <div>
        <h3 class="font-sans font-semibold text-xs tracking-widest uppercase text-muted mb-5">
          {t.footer.contact_heading}
        </h3>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href={`https://line.me/R/ti/p/${t.footer.line_id}`}
              class="font-sans text-sm text-ink hover:text-terra transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`LINE: ${t.footer.line_id} [PLACEHOLDER]`}
            >
              LINE {t.footer.line_id}
              <span class="text-muted text-xs ml-1">[PLACEHOLDER]</span>
            </a>
          </li>
          <li>
            <a
              href={`tel:${t.footer.phone.replace(/\s/g, '')}`}
              class="font-sans text-sm text-ink hover:text-terra transition-colors duration-200"
              aria-label={`Phone: ${t.footer.phone} [PLACEHOLDER]`}
            >
              {t.footer.phone}
              <span class="text-muted text-xs ml-1">[PLACEHOLDER]</span>
            </a>
          </li>
          <li>
            <a
              href={`mailto:${t.footer.email}`}
              class="font-sans text-sm text-ink hover:text-terra transition-colors duration-200"
              aria-label={`Email: ${t.footer.email} [PLACEHOLDER]`}
            >
              {t.footer.email}
              <span class="text-muted text-xs ml-1">[PLACEHOLDER]</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Service areas -->
      <div>
        <h3 class="font-sans font-semibold text-xs tracking-widest uppercase text-muted mb-5">
          {t.footer.areas_heading}
        </h3>
        <ul class="space-y-2" role="list">
          {t.footer.areas.map((area) => (
            <li class="font-serif italic text-sm text-ink">{area}</li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom strip -->
  <div class="border-t border-line">
    <div class="container mx-auto px-6 md:px-10 lg:px-16 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-sans text-muted text-xs">
        {t.footer.copyright} &mdash; {t.footer.built}
      </p>
      <a
        href={`/${lang}/book`}
        class="font-sans font-semibold text-xs text-terra underline underline-offset-4 hover:text-terra-deep transition-colors"
      >
        {t.footer.book_link}
      </a>
    </div>
  </div>

</footer>
