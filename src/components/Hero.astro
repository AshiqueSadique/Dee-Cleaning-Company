---
import type enJson from '../i18n/en.json';
type I18n = typeof enJson;

export interface Props {
  t: I18n;
  lang: 'en' | 'th';
}

const { t, lang } = Astro.props;
---

<section
  id="hero"
  class="relative min-h-[100svh] flex items-center justify-center bg-paper overflow-hidden"
  aria-label="Hero"
>
  <!-- Dust-wipe overlay sweeps left-to-right, "cleaning" the hero into view -->
  <div
    id="hero-wipe"
    aria-hidden="true"
    style="position:absolute;inset:0;background:linear-gradient(90deg,transparent 0%,var(--paper-deep) 35%,var(--paper-deep) 65%,transparent 100%);transform:translateX(-110%);pointer-events:none;z-index:10;opacity:0.6;"
  ></div>

  <div class="container mx-auto px-6 md:px-10 lg:px-16 py-24 text-center" style="position:relative;z-index:1;">

    <p class="hero-item eyebrow mb-10 md:mb-12" aria-label={t.hero.eyebrow}>
      {t.hero.eyebrow}
    </p>

    <h1
      class="hero-item wordmark text-hero font-serif font-medium leading-none text-ink mb-8"
      aria-label={`${t.hero.wordmark_dee} ${t.hero.wordmark_rest}`}
    >
      <em class="italic text-terra">{t.hero.wordmark_dee}</em><br />
      {t.hero.wordmark_rest}
    </h1>

    <div class="hero-item flex items-center justify-center gap-4 mb-8" aria-hidden="true">
      <span id="ornament-left" class="block h-px bg-terra" style="width:0;max-width:80px;"></span>
      <span class="block w-2 h-2 bg-terra rotate-45 flex-shrink-0"></span>
      <span id="ornament-right" class="block h-px bg-terra" style="width:0;max-width:80px;"></span>
    </div>

    <p class="hero-item font-serif italic text-2xl md:text-3xl text-ink mb-4" lang={lang}>
      {t.hero.tagline}
    </p>

    <p class="hero-item font-sans text-muted text-base md:text-lg max-w-md mx-auto mb-12" lang={lang}>
      {t.hero.sub_tagline}
    </p>

    <div class="hero-item flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-5">
      <a href={`/${lang}/book`} class="btn-terra text-sm md:text-base px-8 py-3.5">
        {t.hero.cta_primary}<span class="cta-arrow inline-block ml-1" aria-hidden="true">→</span>
      </a>
      <a href={`/${lang}/#services`} class="link-terra text-sm md:text-base">
        {t.hero.cta_secondary}
      </a>
    </div>

  </div>
</section>
