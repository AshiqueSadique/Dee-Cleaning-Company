---
export const prerender = false;
import { checkAuth } from '../../lib/auth';
import { getStaff, addStaff, deleteStaff } from '../../lib/sheets';
import AdminLayout from '../../layouts/AdminLayout.astro';

if (!checkAuth(Astro.request)) return Astro.redirect('/admin/login');

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'add') {
    const name = (form.get('name') as string || '').trim();
    if (name) {
      await addStaff({
        name,
        phone: (form.get('phone') as string || '').trim(),
        line: (form.get('line') as string || '').trim(),
        email: (form.get('email') as string || '').trim(),
        areas: (form.get('areas') as string || '').trim(),
        notes: (form.get('notes') as string || '').trim(),
      });
      return Astro.redirect('/admin/staff?added=1');
    }
  } else if (action === 'delete') {
    const rowIndex = parseInt(form.get('rowIndex') as string);
    if (!isNaN(rowIndex)) {
      await deleteStaff(rowIndex);
      return Astro.redirect('/admin/staff?deleted=1');
    }
  }
}

const staffList = await getStaff();
const added = Astro.url.searchParams.get('added');
const deleted = Astro.url.searchParams.get('deleted');
---
<AdminLayout title="Staff Management">
  <span slot="header-actions"></span>

  {added && (
    <div style="background:#d1fae5;color:#065f46;padding:14px 20px;margin-bottom:24px;font-size:13px;font-weight:600;">
      ✓ Staff member added successfully.
    </div>
  )}
  {deleted && (
    <div style="background:#fef3c7;color:#92400e;padding:14px 20px;margin-bottom:24px;font-size:13px;font-weight:600;">
      ✓ Staff member removed.
    </div>
  )}

  <div style="display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start;">

    <!-- Staff list -->
    <div>
      <div style="background:#faf7f0;border:1px solid #e0d8c8;padding:28px;">
        <h2 style="font-family:'Fraunces',serif;font-size:18px;font-weight:400;margin-bottom:20px;">
          Cleaners ({staffList.filter(s => s.name).length})
        </h2>
        {staffList.filter(s => s.name).length === 0 ? (
          <p style="color:#6a5e52;font-style:italic;font-size:14px;">No staff added yet.</p>
        ) : (
          <div style="display:flex;flex-direction:column;gap:12px;">
            {staffList.filter(s => s.name).map(staff => (
              <div style="display:flex;align-items:center;justify-content:space-between;padding:16px;background:#f6f1e7;border:1px solid #e0d8c8;gap:16px;">
                <div style="flex:1;min-width:0;">
                  <div style="font-weight:700;font-size:15px;margin-bottom:4px;">{staff.name}</div>
                  <div style="font-size:12px;color:#6a5e52;display:flex;flex-wrap:wrap;gap:12px;">
                    {staff.phone && <span>📞 {staff.phone}</span>}
                    {staff.line && <span>LINE: {staff.line}</span>}
                    {staff.email && <span>✉ {staff.email}</span>}
                    {staff.areas && <span style="color:#b85c3c;">📍 {staff.areas}</span>}
                  </div>
                  {staff.notes && <div style="font-size:11px;color:#8a7e72;margin-top:6px;font-style:italic;">{staff.notes}</div>}
                </div>
                <form method="POST" style="flex-shrink:0;">
                  <input type="hidden" name="action" value="delete"/>
                  <input type="hidden" name="rowIndex" value={staff.rowIndex}/>
                  <button
                    type="submit"
                    onclick="return confirm('Remove this staff member?')"
                    style="padding:7px 14px;background:transparent;border:1px solid #e0d8c8;color:#991b1b;font-family:'Manrope',sans-serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;font-weight:700;cursor:pointer;"
                  >
                    Remove
                  </button>
                </form>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Add staff form -->
    <div>
      <div style="background:#faf7f0;border:1px solid #e0d8c8;padding:28px;">
        <h2 style="font-family:'Fraunces',serif;font-size:18px;font-weight:400;margin-bottom:24px;">Add New Staff</h2>
        <form method="POST">
          <input type="hidden" name="action" value="add"/>

          {[
            { name: 'name', label: 'Full Name *', type: 'text', placeholder: 'e.g. Nong Prae', required: true },
            { name: 'phone', label: 'Phone', type: 'tel', placeholder: '08x-xxx-xxxx', required: false },
            { name: 'line', label: 'LINE ID', type: 'text', placeholder: 'LINE username', required: false },
            { name: 'email', label: 'Email', type: 'email', placeholder: 'for notifications', required: false },
            { name: 'areas', label: 'Service Areas', type: 'text', placeholder: 'e.g. Silom, Sathon', required: false },
            { name: 'notes', label: 'Notes', type: 'text', placeholder: 'Any additional notes', required: false },
          ].map(field => (
            <div style="margin-bottom:18px;">
              <label style="display:block;font-size:9px;letter-spacing:0.3em;text-transform:uppercase;font-weight:700;color:#5a5147;margin-bottom:8px;">{field.label}</label>
              <input
                type={field.type}
                name={field.name}
                placeholder={field.placeholder}
                required={field.required}
                style="width:100%;padding:9px 12px;background:#f6f1e7;border:1px solid #c9bea6;font-family:'Manrope',sans-serif;font-size:14px;color:#1a1a1a;outline:none;"
              />
            </div>
          ))}

          <button
            type="submit"
            style="width:100%;padding:13px;background:#b85c3c;color:#f6f1e7;border:none;font-family:'Manrope',sans-serif;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;font-weight:700;cursor:pointer;margin-top:8px;"
          >
            Add Staff Member
          </button>
        </form>
      </div>
    </div>

  </div>
</AdminLayout>
